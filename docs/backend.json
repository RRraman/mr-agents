
{
  "entities": {
    "Simulation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Simulation",
      "type": "object",
      "description": "Represents a single market simulation run, supporting multiple evaluation modes.",
      "properties": {
        "id": { "type": "string" },
        "input": { "type": "string" },
        "mode": { "type": "string", "enum": ["market_analysis", "brutal_feedback", "first_paying_users"] },
        "overallScore": { "type": "number" },
        "wouldUsePercent": { "type": "number" },
        "wouldPayPercent": { "type": "number" },
        "topAudience": { "type": "string" },
        "summary": { "type": "string" },
        "conversation": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "agent": { "type": "string" },
              "message": { "type": "string" },
              "role": { "type": "string", "enum": ["agent", "user"] }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "agentResultIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "input", "mode", "createdAt"]
    },
    "AgentSimulationResult": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AgentSimulationResult",
      "type": "object",
      "description": "Individual agent feedback for analysis and brutal modes.",
      "properties": {
        "id": { "type": "string" },
        "simulationId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "comment": { "type": "string" },
        "score": { "type": "number" },
        "wouldUse": { "type": "boolean" },
        "reason": { "type": "string" },
        "feedback": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}/simulations/{simulationId}",
        "definition": {
          "entityName": "Simulation",
          "schema": { "$ref": "#/backend/entities/Simulation" },
          "description": "Stores simulation runs with mode-specific data."
        }
      },
      {
        "path": "/users/{userId}/simulations/{simulationId}/agentResults/{agentResultId}",
        "definition": {
          "entityName": "AgentSimulationResult",
          "schema": { "$ref": "#/backend/entities/AgentSimulationResult" },
          "description": "Detailed agent feedback."
        }
      }
    ]
  }
}
